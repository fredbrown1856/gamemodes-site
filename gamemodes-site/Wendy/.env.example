# Wendy Demo Environment Variables

# Cerebras API key for LLM access
CEREBRAS_API_KEY=your-cerebras-key-here

# Secret for session token signing
SESSION_SECRET=your-random-secret-here

# Admin token for protected endpoints (e.g. training data export)
ADMIN_TOKEN=your-admin-token-here

# AES-256 encryption key for training data exports
# Generate one by running:
#   python -c "from training_export import generate_encryption_key; print(generate_encryption_key())"
TRAINING_ENCRYPTION_KEY=

# Salt used for hashing visitor IP addresses (for privacy-preserving rate limiting)
IP_HASH_SALT=gamemodes-wendy
